// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: sessions
// Document ID: 4-digit PIN
// Fields:
//   - hostId: string (required) - UID of the host coach
//   - startTime: number (optional) - Server timestamp of race start
//   - status: string (required, enum: ['waiting', 'active', 'finished'])
//   - raceType: string (optional)
//   - createdAt: number (required)
//
// Subcollection: sessions/{pin}/runners
// Document ID: UUID
// Fields:
//   - name: string (required)
//   - logs: list (optional) - Array of split/lap objects
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isHost(pin) {
      return isAuthenticated() && get(/databases/$(database)/documents/sessions/$(pin)).data.hostId == request.auth.uid;
    }

    function isStarter(pin) {
      let session = get(/databases/$(database)/documents/sessions/$(pin)).data;
      return isAuthenticated() && ('starterId' in session) && session.starterId == request.auth.uid;
    }

    function isValidSession(data) {
      return data.hostId is string &&
             data.status in ['waiting', 'active', 'finished'] &&
             data.createdAt is number &&
             (!('starterId' in data) || data.starterId is string);
    }

    function isValidRunner(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             (!('logs' in data) || data.logs is list) &&
             (!('lastLapTime' in data) || data.lastLapTime is number) &&
             (!('lastSplitTime' in data) || data.lastSplitTime is number) &&
             (!('isRunning' in data) || data.isRunning is bool) &&
             (!('startTime' in data) || data.startTime is number || data.startTime == null);
    }

    match /sessions/{pin} {
      // Anyone with the PIN can read the session state
      allow read: if true;
      
      // Only authenticated users can host
      allow create: if isAuthenticated() && isValidSession(request.resource.data) && request.resource.data.hostId == request.auth.uid;
      
      // Update rules:
      // 1. Starting: Any authenticated user can start if status is 'waiting'. They become the starter.
      // 2. Stopping/Resetting: Only the starter can change status from 'active' to 'finished' or 'waiting'.
      // 3. Other updates: Host can update raceType, etc.
      allow update: if isAuthenticated() && isValidSession(request.resource.data) && (
        // Starting the race
        (resource.data.status == 'waiting' && request.resource.data.status == 'active' && request.resource.data.starterId == request.auth.uid) ||
        // Stopping or Resetting the race (Only starter)
        ((request.resource.data.status == 'finished' || request.resource.data.status == 'waiting') && resource.data.status == 'active' && resource.data.starterId == request.auth.uid) ||
        // Updating raceType or other metadata (Host only)
        (request.resource.data.status == resource.data.status && isHost(pin))
      );

      match /runners/{runnerId} {
        // Anyone in the session can read runners
        allow read: if true;
        
        // Any coach in the session can add or update runner logs
        // We allow this for any authenticated user who knows the PIN
        allow create: if isAuthenticated() && isValidRunner(request.resource.data);
        allow update: if isAuthenticated() && isValidRunner(request.resource.data);
        allow delete: if isAuthenticated();
      }

      match /roster/{athleteId} {
        allow read: if true;
        allow create, update, delete: if isAuthenticated();
      }
    }

    match /users/{userId} {
      match /roster/{athleteId} {
        // Only the owner can read/write their own roster
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }
    }
  }
}
